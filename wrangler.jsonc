{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "compressor-landing-vinext",
  "compatibility_date": "2026-05-22",
  // Static site only — no Worker script. build.command makes bare
  // `npx wrangler deploy` work in Cloudflare Workers Builds.
  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
